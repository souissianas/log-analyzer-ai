{
  "title": "Log Analyzer — Ollama AI Engine",
  "uid": "log-analyzer-ollama",
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Ollama Status",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "up{job=\"log-analyzer-backend\"}",
          "legendFormat": "backend"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": { "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] },
        "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }]
      }
    },
    {
      "type": "stat",
      "title": "Analyses/hour",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "increase(log_analysis_total[1h])", "legendFormat": "analyses" }],
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "type": "stat",
      "title": "Avg Ollama Duration",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(ollama_request_duration_seconds_sum[5m]) / rate(ollama_request_duration_seconds_count[5m])",
          "legendFormat": "avg"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "p95 Ollama Latency",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(ollama_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": {
        "colorMode": "background",
        "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 30, "color": "orange" }, { "value": 90, "color": "red" }] }
      }
    },
    {
      "type": "stat",
      "title": "Timeout Rate",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{path=~\"/ollama/.*\",status=\"504\"}[5m])) or vector(0)",
          "legendFormat": "timeouts/s"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 0.01, "color": "red" }] }
      }
    },
    {
      "type": "timeseries",
      "title": "Ollama Duration Heatmap (p50 / p95 / p99)",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(ollama_request_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(ollama_request_duration_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(ollama_request_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } }
    },
    {
      "type": "timeseries",
      "title": "Analyses & Errors Detected",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "increase(log_analysis_total[5m])", "legendFormat": "analyses" },
        { "expr": "increase(log_errors_detected_total[5m])", "legendFormat": "errors detected" }
      ]
    },
    {
      "type": "logs",
      "title": "Backend Logs (Loki)",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=\"backend\"} | json | level =~ \"ERROR|WARNING\"",
          "legendFormat": ""
        }
      ]
    }
  ]
}
